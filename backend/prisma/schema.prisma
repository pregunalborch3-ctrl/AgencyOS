generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String     @id @default(uuid())
  name               String
  email              String     @unique
  passwordHash       String
  role               String     @default("member")
  createdAt          DateTime   @default(now())
  lastLoginAt        DateTime?
  stripeCustomerId   String?
  subscriptionId     String?
  subscriptionStatus String?
  subscriptionEnd    DateTime?
  trialEnd           DateTime?
  priceId            String?
  cancelAtPeriodEnd  Boolean    @default(false)
  freeUsed           Boolean    @default(false)
  agencySettings     Json?
  campaigns          Campaign[]
  briefings          Briefing[]
  budgets            Budget[]
  calendarPosts      CalendarPost[]
  competitors        Competitor[]
  contentHistory     ContentHistory[]
  apiKeys            ApiKey[]
}

model Campaign {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  niche     String
  objective String
  data      Json
  createdAt DateTime @default(now())

  @@index([userId])
}

model Briefing {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientName      String
  brand           String   @default("")
  projectName     String
  projectType     String   @default("")
  objective       String   @default("")
  targetAudience  String   @default("")
  ageRange        String   @default("")
  location        String   @default("")
  keyMessage      String   @default("")
  tone            String   @default("")
  mandatories     String   @default("")
  restrictions    String   @default("")
  deliverables    String   @default("")
  startDate       String   @default("")
  endDate         String   @default("")
  budget          String   @default("")
  competitors     String   @default("")
  references      String   @default("")
  additionalNotes String   @default("")
  createdAt       DateTime @default(now())

  @@index([userId])
}

model Budget {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectName      String
  client           String   @default("")
  currency         String   @default("EUR")
  items            Json     @default("[]")
  agencyFeePercent Float    @default(0)
  taxPercent       Float    @default(0)
  notes            String   @default("")
  createdAt        DateTime @default(now())

  @@index([userId])
}

model CalendarPost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  date      String
  platform  String
  content   String
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Competitor {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  url       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ContentHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Json
  createdAt DateTime @default(now())

  @@index([userId])
}

model ApiKey {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  keyHash   String    @unique
  keyPrefix String
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
