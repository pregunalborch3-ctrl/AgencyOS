# Base de datos (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# JWT Authentication
JWT_SECRET="genera-uno-con: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
JWT_EXPIRES_IN="7d"

# Anthropic (IA)
ANTHROPIC_API_KEY="sk-ant-..."

# Stripe (pagos)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_STARTER="price_..."
STRIPE_PRICE_ID_PRO="price_..."
STRIPE_PRICE_ID_ENTERPRISE="price_..."

# Resend (emails)
RESEND_API_KEY="re_..."
# Dirección de envío — debe ser de un dominio verificado en Resend (ej: noreply@tudominio.com)
# Si no está configurada, se usa onboarding@resend.dev (solo para pruebas)
RESEND_FROM="Agenciesos <noreply@agenciesos.com>"

# URLs
FRONTEND_URL="https://tu-dominio.com"
PORT=3001
NODE_ENV="production"
